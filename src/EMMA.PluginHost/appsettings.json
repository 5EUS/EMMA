{
  "PluginHost": {
    "ManifestDirectory": "manifests",
    "RepositoryDirectory": "repositories",
    "HandshakeTimeoutSeconds": 5,
    "HandshakeOnStartup": true,
    "SandboxRootDirectory": "sandbox",
    "SandboxEnabled": true,
    "BudgetWatchIntervalSeconds": 30,
    "MaxCpuBudgetMs": 250,
    "MaxMemoryMb": 512,
    "StartupTimeoutSeconds": 5,
    "StartupProbeIntervalMs": 200,
    "TimeoutBackoffSeconds": 5,
    "MaxTimeoutRetries": 3,
    "ProbeTimeoutSeconds": 5,
    "MaxConcurrentCallsPerPlugin": 8,
    "PluginLogMaxLines": 200,
    "PluginIdleTimeoutSeconds": 120,
    "PluginIdleSweepSeconds": 30,
    "RepositoryRequestTimeoutSeconds": 30,
    "RepositoryMaxCatalogBytes": 2097152,
    "RepositoryMaxArtifactBytes": 536870912,
    "AllowInsecureRepositoryHttp": false,
    "RepositoryHttpUserAgent": "EMMA.PluginHost/1.0"
  }
}
