(version 1)
(deny default)
(allow process*)
(allow sysctl-read)
(allow file-read* (subpath "sandbox/demo"))
(allow file-write* (subpath "sandbox/demo"))
(allow file-read* (subpath "/usr"))
(allow file-read* (subpath "/bin"))
(allow file-read* (subpath "/sbin"))
(allow file-read* (subpath "/System"))
(allow file-read* (subpath "/Library"))
(allow file-read* (subpath "/plugin-data"))
(allow network-outbound (remote domain "example.com"))
