# Copy to .signing.env and source it before packaging.
export EMMA_PLUGIN_REPOSITORY_ID="change-me"
export EMMA_PLUGIN_SIGNING_KEY_ID="change-me-release-key"

# Point this to your local delegated private key PEM.
# Example: /home/you/Git/plugin-repo/.keys/change-me-release-key.private.pem
export EMMA_PLUGIN_SIGNING_PRIVATE_KEY_BASE64="$(base64 -w 0 /absolute/path/to/change-me-release-key.private.pem)"