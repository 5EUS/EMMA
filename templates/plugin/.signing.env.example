# Copy to .signing.env and source it before packaging.
# Replace values to match your repository trust/delegation configuration.
export EMMA_PLUGIN_REPOSITORY_ID="emma-test"
export EMMA_PLUGIN_SIGNING_KEY_ID="emma-test-shared-release-2026-q2"

# Preferred: base64 PEM private key from your delegated signer key file.
# Example: /home/you/Git/emma-test-repo/.keys/emma-test-shared-release-2026-q2.private.pem
export EMMA_PLUGIN_SIGNING_PRIVATE_KEY_BASE64="$(base64 -w 0 /absolute/path/to/delegated.private.pem)"

# Optional signature validity metadata
# export EMMA_PLUGIN_SIGNATURE_ISSUED_AT_UTC="2026-04-05T00:00:00Z"
# export EMMA_PLUGIN_SIGNATURE_EXPIRES_AT_UTC="2026-07-01T00:00:00Z"
